# ─── Copier ce fichier en .env et renseigner les valeurs ────────
# cp .env.example .env

# ── Chatbot (Anthropic Claude) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Cloud (TTS / Translation) ────────────────────────────
GOOGLE_API_KEY=

# ── LibreTranslate (optionnel — fallback traduction) ─────────────
LIBRETRANSLATE_URL=

# ── URLs inter-services (ne pas modifier en Docker) ──────────────
# Ces valeurs sont déjà définies dans docker-compose.yml
# PYTHON_BACKEND_URL=http://backend-python:8001
# REDIS_URL=redis://redis:6379
# FRONTEND_URL=http://localhost:3000
